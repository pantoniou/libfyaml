.INDENT 0.0
.INDENT 3.5
.sp
.EX
#define PRINT_ITEM(x)  printf(\(dq%d\en\(dq, x);
FY_CPP_MAP(PRINT_ITEM, 1, 2, 3)
// expands to: printf(\(dq%d\en\(dq, 1); printf(\(dq%d\en\(dq, 2); printf(\(dq%d\en\(dq, 3);
.EE
